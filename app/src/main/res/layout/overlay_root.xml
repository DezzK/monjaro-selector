<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="32dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/overlay_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/overlay_card"
        app:cardCornerRadius="@dimen/overlay_corner"
        app:cardElevation="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/overlay_recycler"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="@dimen/overlay_padding_horizontal"
            android:paddingVertical="@dimen/overlay_padding_vertical" />
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
