<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/row_height"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="@dimen/card_corner"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkbox_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <FrameLayout
            android:layout_width="@dimen/row_icon"
            android:layout_height="@dimen/row_icon"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_pill_inactive">

            <ImageView
                android:id="@+id/icon_mode"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                tools:src="@drawable/ic_mode_comfort"
                tools:tint="@color/accent_comfort" />
        </FrameLayout>

        <TextView
            android:id="@+id/label_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            tools:text="Комфорт" />

        <ImageView
            android:id="@+id/drag_handle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_drag_indicator" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
