<?xml version="1.0" encoding="utf-8"?>
<resources>
    <dimen name="page_padding">24dp</dimen>
    <dimen name="card_corner">20dp</dimen>
    <dimen name="card_padding">16dp</dimen>
    <dimen name="row_height">72dp</dimen>
    <dimen name="row_icon">36dp</dimen>
    <!-- ImageView size for icons rendered through ShadowDrawable. The shadow
         reserves the outer ~20%, so the actual glyph ends up close to the
         bare-icon size we used before. -->
    <dimen name="row_icon_image">28dp</dimen>
    <dimen name="chip_icon_size">22dp</dimen>
    <dimen name="overlay_corner">48dp</dimen>
    <dimen name="overlay_padding_horizontal">56dp</dimen>
    <dimen name="overlay_padding_vertical">40dp</dimen>
    <!-- Natural sizes are sized for the active state (scale = 1.0). Inactive
         pills downscale from here, so VectorDrawables are always rasterized
         at the largest size they'll ever appear and only sampled down — the
         GPU bitmap-scales every View transform, so we never let it upscale a
         cached raster. -->
    <dimen name="overlay_pill_icon">152dp</dimen>
    <dimen name="overlay_pill_icon_image">113dp</dimen>
    <dimen name="overlay_pill_label">28sp</dimen>
    <dimen name="overlay_pill_min_width">180dp</dimen>
    <dimen name="overlay_item_spacing">12dp</dimen>
</resources>
